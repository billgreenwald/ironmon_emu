<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Vertical boundary at 70% — right edge of game zone -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gameZoneBoundary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.70" />

    <TextView
        android:id="@+id/fps_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS: 0"
        android:textColor="#00FF00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="#80000000"
        android:padding="8dp"
        android:elevation="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tools_btn"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="tools"
        android:gravity="center"
        android:textColor="#303030"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="@drawable/btnbackgroud"
        android:layout_marginBottom="8dp"
        android:elevation="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/gameZoneBoundary"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include layout="@layout/padboard"
        android:id="@+id/padboardInclude"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/gameZoneBoundary" />

</androidx.constraintlayout.widget.ConstraintLayout>
